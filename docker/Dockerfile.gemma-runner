# Official Ollama image — Ollama binary already installed and validated
FROM ollama/ollama:latest

ENV OLLAMA_HOST=0.0.0.0
ENV DEBIAN_FRONTEND=noninteractive

# Add Python + pip for LiteLLM
RUN apt-get update && apt-get install -y \
    python3 python3-pip curl \
    && rm -rf /var/lib/apt/lists/*

# Pull Gemma model at build time — baked into image layer, zero pull at runtime
RUN ollama serve & \
    OLLAMA_PID=$! && \
    sleep 8 && \
    ollama pull gemma4:e4b && \
    printf 'FROM gemma4:e4b\nPARAMETER num_ctx 128000\n' > /tmp/Modelfile && \
    ollama create gemma-local -f /tmp/Modelfile && \
    ollama list && \
    kill $OLLAMA_PID 2>/dev/null || true

# Install LiteLLM proxy
RUN pip3 install 'litellm[proxy]'

# Write LiteLLM config that routes claude-3-haiku → gemma-local
RUN mkdir -p /etc/litellm && cat > /etc/litellm/config.yaml << 'EOF'
model_list:
  - model_name: claude-3-haiku-20240307
    litellm_params:
      model: ollama_chat/gemma-local
      api_base: http://localhost:11434
EOF

# Startup script: launch Ollama + LiteLLM in foreground
COPY docker/entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

EXPOSE 4000 11434

ENTRYPOINT ["/entrypoint.sh"]
