# Official Ollama image — Ollama binary already installed and validated
FROM ollama/ollama:latest

ENV OLLAMA_HOST=0.0.0.0
ENV DEBIAN_FRONTEND=noninteractive

# Add Python + build tools for LiteLLM
RUN apt-get update && apt-get install -y \
    python3 python3-pip python3-dev \
    build-essential curl \
    && rm -rf /var/lib/apt/lists/*

# Pull model at build time — baked into image layer, zero pull at runtime
# llama3.2:3b chosen for tool-use support (gemma3 does not support tools)
RUN ollama serve & \
    OLLAMA_PID=$! && \
    sleep 8 && \
    ollama pull llama3.2:3b && \
    printf 'FROM llama3.2:3b\nPARAMETER num_ctx 128000\n' > /tmp/Modelfile && \
    ollama create llm-local -f /tmp/Modelfile && \
    ollama list && \
    kill $OLLAMA_PID 2>/dev/null || true

# Install LiteLLM proxy
RUN pip3 install --break-system-packages --no-cache-dir \
    --prefer-binary 'litellm[proxy]'

# Write LiteLLM config that routes claude-3-haiku → gemma-local
RUN mkdir -p /etc/litellm && cat > /etc/litellm/config.yaml << 'EOF'
model_list:
  - model_name: claude-3-haiku-20240307
    litellm_params:
      model: ollama_chat/llm-local
      api_base: http://localhost:11434
EOF

# Startup script: launch Ollama + LiteLLM in foreground
COPY docker/entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

EXPOSE 4000 11434

ENTRYPOINT ["/entrypoint.sh"]
